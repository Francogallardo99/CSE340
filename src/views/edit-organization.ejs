<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>

 <form action="/edit-organization/<%= organization.organization_id %>" method="POST">
    <div class="form-group">
      <label for="name">Organization Name</label>
      <input
        type="text"
        id="name"
        name="name"
        value="<%= organization.name %>"
      />
    </div>

    <div class="form-group">
      <label for="description">Description</label>
      <textarea
        id="description"
        name="description"
        ><%= organization.description %></textarea>
    </div>

    <div class="form-group">
      <label for="contactEmail">Contact Email</label>
      <input
        type="text"
        id="contactEmail"
        name="contactEmail"
        value="<%= organization.contact_email %>"
      />
    </div>

    <div class="form-group">
      <label for="logo">Logo Filename</label>
      <input
        type="text"
        id="logo"
        name="logo"
        value="<%= organization.logo_filename %>"
      />   
    <button type="submit">Update Organization</button>
  </form>
  
</main>
<%- include('partials/footer') %>