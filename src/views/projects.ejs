<%- include('partials/header') %>
    <main>
        <h1><%= title %></h1>
        <ul>
            <% projects.forEach(project => { %>
                <li>
                    <strong><a href="/project/<%= project.project_id %>"><%= project.title %></a></strong><%= project.description %>
                    <br>
                    Location: <%= project.location %>
                    <br>
                    Date: <%= project.date %>
                    <br>
                    Organization: <a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a>
                </li>
            <% }); %>
        </ul>
    </main>
<%- include('partials/footer') %>