<%- include('partials/header') %>
    <main>
        <h1><%= title %></h1>
        
        <h2><%= project.title %></h2>
        <p><strong>Description:</strong> <%= project.description %></p>
        <p><strong>Location:</strong> <%= project.location %></p>
        <p><strong>Date:</strong> <%= project.date %></p>
        <p><strong>Organization:</strong> <a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a></p>
        <p><strong>Categories:</strong>
            <% categories.forEach(category => { %>
                <a href="/category/<%= category.category_id %>"><%= category.category_name %></a><% if (categories.indexOf(category) !== categories.length - 1) { %>, <% } %>
            <% }); %>
        </p>
        <br>
        <a href="/projects">Back to Projects</a> | <a href="/assign-categories/<%= project.project_id %>">Assign Categories</a> | <a href="/edit-project/<%= project.project_id %>">Edit Project</a>
    </main>
<%- include('partials/footer') %>