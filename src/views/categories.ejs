<%- include('partials/header') %>
    <main>
        <h1><%= title %></h1>
        <ul>
            <% categories.forEach(category => { %>
                <li><strong><a href="/category/<%= category.category_id %>"><%= category.category_name %></a></strong></li>
            <% }); %>
        </ul>
        <a href="/new-category">Create a Category</a>
    </main>
    
<%- include('partials/footer') %>