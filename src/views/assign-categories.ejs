<%- include('partials/header') %>
    <main>
        <h1><%= title %></h1>
        <h2>Assign Categories to <%= project.title %></h2>
        <form action="/assign-categories/<%= project.project_id %>" method="POST">
            <% allCategories.forEach(category => { %>
                <div>
                    <input type="checkbox" id="category-<%= category.category_id %>" name="categories" value="<%= category.category_id %>" <%= assignedCategories.some(ac => ac.category_id === category.category_id) ? 'checked' : '' %>>
                    <label for="category-<%= category.category_id %>"><%= category.category_name %></label>
                </div>
            <% }); %>
            <button type="submit">Save Categories</button>
        </form>
    </main>

<%- include('partials/footer') %>